<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Générateur de Documents avec Catalogue</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --text-color: #1e293b;
            --border-color: #cbd5e1;
            --bg-light: #f8fafc;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, sans-serif; }
        body { background-color: var(--bg-light); color: var(--text-color); padding: 20px; font-size: 14px; }
        .container { max-width: 850px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }

        /* Panneau Configuration */
        .config-panel { background: #f1f5f9; padding: 15px; border-radius: 6px; margin-bottom: 25px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
        select, button, input { padding: 8px 12px; border: 1px solid var(--border-color); border-radius: 4px; font-size: 14px; outline: none; background: #fff; }
        button { cursor: pointer; }
        
        .btn-print { background-color: var(--primary-color); color: white; border: none; font-weight: bold; margin-left: auto; }
        .btn-add { background-color: #10b981; color: white; border: none; }
        .btn-import { background-color: #475569; color: white; border: none; }
        #file-input { display: none; }

        /* Remise */
        .remise-toggle-label { display: flex; align-items: center; gap: 6px; background: #fff; padding: 6px 10px; border: 1px solid var(--border-color); border-radius: 4px; cursor: pointer; }
        .remise-toggle-label input { width: auto; padding: 0; }
        .remise-row { display: flex; justify-content: space-between; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--border-color); color: #b45309; }
        .remise-row select { padding: 4px 6px; font-size: 13px; border: 1px solid var(--border-color); border-radius: 4px; }
        .remise-row input[type="number"] { width: 70px; text-align: right; padding: 4px 6px; font-size: 13px; }

        /* En-tête & Structure */
        .document-header { display: flex; justify-content: space-between; margin-bottom: 30px; gap: 20px; }
        .doc-title { font-size: 28px; text-transform: uppercase; color: var(--primary-color); font-weight: 800; }
        .editable { border: 1px dashed transparent; transition: border 0.2s; }
        .editable:hover, .editable:focus { border-color: var(--primary-color); background: #f8fafc; }
        .grid-two-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
        .block-info h3 { margin-bottom: 8px; font-size: 14px; color: #64748b; text-transform: uppercase; }

        /* Table Responsive */
        .table-responsive { width: 100%; overflow-x: auto; margin-bottom: 30px; }
        table { width: 100%; border-collapse: collapse; min-width: 600px; }
        th, td { padding: 12px; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
        th { background-color: var(--bg-light); font-weight: 600; }
        
        /* Inputs à l'intérieur du tableau */
        .cell-select, .cell-input { width: 100%; border: none; background: transparent; padding: 4px; font-size: 14px; }
        .cell-select:focus, .cell-input:focus { background: #f1f5f9; outline: none; }

        .col-qty, .col-days, .col-price, .col-total { text-align: right; width: 110px; }
        .col-actions { text-align: center; width: 50px; }
        .btn-delete { background: #ef4444; color: white; border: none; padding: 4px 8px; border-radius: 4px; }

        /* Pied de page */
        .document-footer { display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
        .notes-zone { flex: 1; min-width: 250px; }
        .totals-zone { width: 250px; }
        .total-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border-color); }
        .total-row.grand-total { font-weight: bold; font-size: 16px; color: var(--primary-color); border-bottom: 2px solid var(--primary-color); }

        /* Mobile */
        @media (max-width: 600px) {
            .document-header { flex-direction: column; text-align: center; }
            .grid-two-cols { grid-template-columns: 1fr; }
            .config-panel { flex-direction: column; align-items: stretch; }
            .btn-print { margin-left: 0; width: 100%; }
            .totals-zone { width: 100%; }
        }

        /* Impression */
        @media print {
            .config-panel, .col-actions, .btn-delete, .btn-add { display: none !important; }
            .container { box-shadow: none; padding: 0; }
            select { -webkit-appearance: none; -moz-appearance: none; appearance: none; border: none !important; background: transparent !important; }
            input { border: none !important; background: transparent !important; text-align: right; }
        }
    </style>
</head>
<body>

<div class="container">

    <div class="config-panel">
        <select id="doc-type" onchange="changeDocType()">
            <option value="Facture">Facture</option>
            <option value="Devis">Devis</option>
            <option value="Bon de Livraison">Bon de Livraison</option>
        </select>
        
        <button class="btn-import" onclick="loadCatalogueFromGitHub()">🔄 Actualiser le catalogue</button>
        <span id="import-status" style="font-size:12px; color:#10b981; font-weight:bold;"></span>

        <button class="btn-add" onclick="addItemRow()">+ Ajouter ligne</button>

        <label class="remise-toggle-label">
            <input type="checkbox" id="remise-toggle" onchange="toggleRemise()">
            Remise
        </label>

        <button class="btn-print" onclick="window.print()">🖨️ Imprimer / PDF</button>
    </div>

    <div class="document-header">
        <div>
            <div class="doc-title" id="title-display">Facture</div>
            <div class="editable" contenteditable="true" style="margin-top: 5px; color: #64748b;">
                N° <span id="doc-num">FA-2026-001</span><br>
                Date:<input type="date" id="doc-date" style="border:1px dashed #cbd5e1; padding:2px; font-family:inherit; font-size:14px;">
            </div>
        </div>
        <div class="editable" contenteditable="true" style="text-align: left;">
            <strong>Link In Events S.U.A.R.L</strong><br>
            Organisation de Salons professionnels et Congrès<br> 
            Adresse : Rue Bir Lazaar Beni Khiar Nabeul 8060<br>
            Mail: linkin.events.contact@gmail.com<br>
            Tél : (+216) 50 477 546<br>
            Matricule Fiscale: 1958814L/A/M/000<br>
            BH Bank RIB: 14016016101701080312<br>
        </div>
    </div>

    <div class="grid-two-cols">
        <div class="block-info">
            <h3>Objet</h3>
            <div class="editable" contenteditable="true">Mise à disposition matériel événementiel</div>
        </div>
        <div class="block-info">
            <h3>Client</h3>
            <div class="editable" contenteditable="true">proposition</div>
        </div>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Désignation / Article</th>
                    <th class="col-qty">Qté</th>
                    <th class="col-days" id="th-days">Jours</th>
                    <th class="col-price" id="th-price">Prix Unit.</th>
                    <th class="col-total" id="th-total">Total</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody id="invoice-items">
            </tbody>
        </table>
    </div>

    <div class="document-footer">
        <div class="notes-zone">
            <div style="font-weight: bold; margin-bottom: 5px;">Observations :</div>
            <div class="editable" contenteditable="true" style="min-height: 50px; color: #64748b;">Conditions de paiement standard.</div>
        </div>
        <div class="totals-zone" id="financial-totals">
            <div class="total-row"><span id="label-ht">Total HT</span><span id="total-ht-brut">0.000</span></div>
            <div class="remise-row" id="remise-row" style="display:none;">
                <span>Remise
                    <select id="remise-type" onchange="calculateTotals()">
                        <option value="pourcentage">%</option>
                        <option value="montant">DT</option>
                    </select>
                </span>
                <input type="number" id="remise-valeur" value="0" min="0" step="0.001" oninput="calculateTotals()">
            </div>
            <div class="total-row" id="row-ht-net" style="display:none;"><span>Total HT net</span><span id="total-ht">0.000</span></div>
            <div class="total-row"><span>TVA (19%)</span><span id="total-tva">0.000</span></div>
            <div class="total-row" id="row-timbre"><span>Timbre Fiscal</span><span id="total-timbre">1.000</span></div>
            <div class="total-row grand-total"><span>Total TTC</span><span id="total-ttc">0.000</span></div>
        </div>
    </div>

    <div id="montant-lettres-row" style="display:none; margin-top: 20px; padding-top: 15px; border-top: 1px dashed var(--border-color); font-style: italic;">
        La présente facture est arrêtée à la somme de : <strong id="montant-lettres-text"></strong>
    </div>
</div>

<script>
    // Variable globale pour stocker le catalogue importé
    let catalogueProduits = [];

    // Lien du catalogue sur GitHub (fichier .txt, format "nom;prix" par ligne)
    const CATALOGUE_URL = 'https://raw.githubusercontent.com/bechirrafrafi-beep/soundlightrafrafi/b5b97e486373a115cc4768a66c98e9e9d2c2096f/catalogue.txt';

    // Charge le catalogue depuis GitHub
    async function loadCatalogueFromGitHub() {
        const status = document.getElementById('import-status');
        status.style.color = '#2563eb';
        status.innerText = '⏳ Chargement du catalogue...';

        try {
            const response = await fetch(CATALOGUE_URL, { cache: 'no-store' });
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const text = await response.text();

            const lines = text.split('\n');
            catalogueProduits = []; // Réinitialisation

            lines.forEach(line => {
                if (line.trim() === "") return;
                const parts = line.split(';');
                if (parts.length >= 2) {
                    catalogueProduits.push({
                        nom: parts[0].trim(),
                        prix: parseFloat(parts[1].trim().replace(',', '.')) || 0
                    });
                }
            });

            status.style.color = '#10b981';
            status.innerText = `✓ ${catalogueProduits.length} produits chargés`;

            // Rafraîchir les lignes existantes pour leur appliquer la liste déroulante
            updateAllRowsToSelect();
        } catch (err) {
            console.error('Erreur de chargement du catalogue:', err);
            status.style.color = '#ef4444';
            status.innerText = '✗ Échec du chargement du catalogue';
        }
    }

    // Crée les options HTML pour la liste déroulante
    function generateOptionsHTML() {
        let options = '<option value="">-- Choisir ou taper un article --</option>';
        catalogueProduits.forEach(prod => {
            options += `<option value="${prod.nom}" data-price="${prod.prix}">${prod.nom}</option>`;
        });
        return options;
    }

    // Ajoute une nouvelle ligne
    function addItemRow() {
        const tbody = document.getElementById('invoice-items');
        const tr = document.createElement('tr');
        
        // Si un catalogue est chargé, on met un select, sinon un champ libre éditable
        const hasCatalogue = catalogueProduits.length > 0;
        
        tr.innerHTML = `
            <td>
                ${hasCatalogue ? 
                    `<select class="cell-select" onchange="handleProductChange(this)">${generateOptionsHTML()}</select>` : 
                    `<div class="editable" contenteditable="true" style="padding:4px;">Nouvel article</div>`
                }
            </td>
            <td class="col-qty"><input type="number" class="cell-input" value="1" min="1" style="text-align:right;" oninput="calculateTotals()"></td>
            <td class="col-days"><input type="number" class="cell-input" value="1" min="1" style="text-align:right;" oninput="calculateTotals()"></td>
            <td class="col-price"><input type="text" class="cell-input" value="0.000" style="text-align:right;" oninput="calculateTotals()"></td>
            <td class="col-total row-total" style="text-align:right;">0.000</td>
            <td class="col-actions"><button class="btn-delete" onclick="deleteRow(this)">✕</button></td>
        `;
        
        tbody.appendChild(tr);
        applyBLVisibility();
        calculateTotals();
    }

    // Déclenché quand on choisit un produit dans la liste déroulante
    function handleProductChange(selectElement) {
        const selectedOption = selectElement.options[selectElement.selectedIndex];
        const price = selectedOption.getAttribute('data-price');
        
        const row = selectElement.closest('tr');
        const priceInput = row.querySelector('.col-price input');
        
        if(price && priceInput) {
            priceInput.value = parseFloat(price).toFixed(3);
        }
        calculateTotals();
    }

    // Met à jour toutes les lignes quand le catalogue est importé
    function updateAllRowsToSelect() {
        const rows = document.querySelectorAll('#invoice-items tr');
        rows.forEach(row => {
            const firstCell = row.querySelector('td');
            firstCell.innerHTML = `<select class="cell-select" onchange="handleProductChange(this)">${generateOptionsHTML()}</select>`;
        });
        calculateTotals();
    }

    function deleteRow(button) {
        button.closest('tr').remove();
        calculateTotals();
    }

    // Affiche/masque la ligne de remise
    function toggleRemise() {
        const enabled = document.getElementById('remise-toggle').checked;
        document.getElementById('remise-row').style.display = enabled ? 'flex' : 'none';
        document.getElementById('row-ht-net').style.display = enabled ? 'flex' : 'none';
        document.getElementById('label-ht').innerText = enabled ? 'Total HT brut' : 'Total HT';
        calculateTotals();
    }

    // Calcule le montant de la remise selon le type choisi (% ou montant fixe)
    function getRemiseMontant(totalHTBrut) {
        const enabled = document.getElementById('remise-toggle').checked;
        if (!enabled) return 0;
        const type = document.getElementById('remise-type').value;
        const valeur = parseFloat(document.getElementById('remise-valeur').value) || 0;
        if (type === 'pourcentage') {
            return totalHTBrut * (valeur / 100);
        }
        return valeur;
    }

    // ---------- Conversion d'un montant en toutes lettres (Dinars / Millimes) ----------

    const NOMBRES_0_19 = ["Zéro","Un","Deux","Trois","Quatre","Cinq","Six","Sept","Huit","Neuf","Dix","Onze","Douze","Treize","Quatorze","Quinze","Seize","Dix-Sept","Dix-Huit","Dix-Neuf"];

    function convertirDizaines(n) {
        if (n < 20) return NOMBRES_0_19[n];
        const dizaine = Math.floor(n / 10);
        const unite = n % 10;

        if (dizaine === 7 || dizaine === 9) {
            const base = dizaine === 7 ? "Soixante" : "Quatre-Vingt";
            if (dizaine === 7 && unite === 1) return base + "-Et-Onze";
            return base + "-" + NOMBRES_0_19[10 + unite];
        }
        if (dizaine === 8) {
            if (unite === 0) return "Quatre-Vingts";
            return "Quatre-Vingt-" + NOMBRES_0_19[unite];
        }

        const bases = { 2: "Vingt", 3: "Trente", 4: "Quarante", 5: "Cinquante", 6: "Soixante" };
        const base = bases[dizaine];
        if (unite === 0) return base;
        if (unite === 1) return base + "-Et-Un";
        return base + "-" + NOMBRES_0_19[unite];
    }

    function convertirCentaines(n) {
        if (n < 100) return convertirDizaines(n);
        const centaine = Math.floor(n / 100);
        const reste = n % 100;

        let resultat = centaine === 1 ? "Cent" : NOMBRES_0_19[centaine] + " Cent";
        if (reste === 0 && centaine > 1) resultat += "s";
        if (reste > 0) resultat += " " + convertirDizaines(reste);
        return resultat;
    }

    function convertirNombreEnLettres(n) {
        n = Math.round(n);
        if (n === 0) return "Zéro";

        const milliard = Math.floor(n / 1e9); n %= 1e9;
        const million = Math.floor(n / 1e6); n %= 1e6;
        const mille = Math.floor(n / 1e3); n %= 1e3;
        const reste = n;

        const parts = [];
        if (milliard > 0) parts.push(milliard === 1 ? "Un Milliard" : convertirCentaines(milliard) + " Milliards");
        if (million > 0) parts.push(million === 1 ? "Un Million" : convertirCentaines(million) + " Millions");
        if (mille > 0) parts.push(mille === 1 ? "Mille" : convertirCentaines(mille) + " Mille");
        if (reste > 0) parts.push(convertirCentaines(reste));

        return parts.join(" ");
    }

    // Transforme un montant (ex: 1234.567) en texte "Mille Deux Cent Trente-Quatre Dinars Et Cinq Cent Soixante-Sept Millimes"
    function montantEnLettres(montant) {
        const fixe = (Math.round(montant * 1000) / 1000).toFixed(3);
        const [entierStr, decStr] = fixe.split('.');
        const entier = parseInt(entierStr, 10);
        const millimes = parseInt(decStr, 10);

        let texte = convertirNombreEnLettres(entier) + (entier <= 1 ? " Dinar" : " Dinars");
        if (millimes > 0) {
            texte += " Et " + convertirNombreEnLettres(millimes) + (millimes <= 1 ? " Millime" : " Millimes");
        }
        return texte;
    }

    // Affiche (ou masque) la ligne "montant en toutes lettres" — uniquement pour les factures
    function updateMontantLettres(totalTTC) {
        const row = document.getElementById('montant-lettres-row');
        const estFacture = document.getElementById('doc-type').value === "Facture";

        if (!estFacture) {
            row.style.display = 'none';
            return;
        }
        row.style.display = 'block';
        document.getElementById('montant-lettres-text').innerText = montantEnLettres(totalTTC);
    }

    function calculateTotals() {
        const rows = document.querySelectorAll('#invoice-items tr');
        let totalHTBrut = 0;

        rows.forEach(row => {
            const qtyInput = row.querySelector('.col-qty input');
            const daysInput = row.querySelector('.col-days input');
            const priceInput = row.querySelector('.col-price input');
            const rowTotalCell = row.querySelector('.row-total');

            if (qtyInput && daysInput && priceInput) {
                let qty = parseFloat(qtyInput.value) || 0;
                let days = parseFloat(daysInput.value) || 0;
                let price = parseFloat(priceInput.value.replace(',', '.')) || 0;
                
                // Calcul prenant en compte les jours : Qté * Jours * Prix Unit
                let rowTotal = qty * days * price;
                totalHTBrut += rowTotal;
                if (rowTotalCell) rowTotalCell.innerText = rowTotal.toFixed(3);
            }
        });

        let remiseMontant = getRemiseMontant(totalHTBrut);
        if (remiseMontant > totalHTBrut) remiseMontant = totalHTBrut; // la remise ne peut pas dépasser le total
        let totalHTNet = totalHTBrut - remiseMontant;

        let isBL = document.getElementById('doc-type').value === "Bon de Livraison";
        let tva = totalHTNet * 0.19; // TVA 19%, calculée après remise
        let timbre = isBL ? 0 : 1.000; // Pas de timbre sur les Bons de livraison
        let totalTTC = totalHTNet + tva + timbre;

        document.getElementById('total-ht-brut').innerText = totalHTBrut.toFixed(3);
        document.getElementById('total-ht').innerText = totalHTNet.toFixed(3);
        document.getElementById('total-tva').innerText = tva.toFixed(3);
        document.getElementById('total-timbre').innerText = timbre.toFixed(3);
        document.getElementById('total-ttc').innerText = totalTTC.toFixed(3);

        updateMontantLettres(totalTTC);
    }

    function changeDocType() {
        const type = document.getElementById('doc-type').value;
        document.getElementById('title-display').innerText = type;
        const docNum = document.getElementById('doc-num');
        
        if(type === "Facture") docNum.innerText = "FA-2026-001";
        else if(type === "Devis") docNum.innerText = "DE-2026-001";
        else if(type === "Bon de Livraison") docNum.innerText = "BL-2026-001";
        
        applyBLVisibility();
        calculateTotals();
    }

    function applyBLVisibility() {
        const isNotBL = document.getElementById('doc-type').value !== "Bon de Livraison";
        const displayStyle = isNotBL ? '' : 'none';
        
        document.getElementById('th-price').style.display = displayStyle;
        document.getElementById('th-total').style.display = displayStyle;
        document.getElementById('financial-totals').style.display = displayStyle;
        document.getElementById('row-timbre').style.display = displayStyle;
        
        document.querySelectorAll('.col-price').forEach(col => col.style.display = displayStyle);
        document.querySelectorAll('.col-total').forEach(col => col.style.display = displayStyle);
    }

    // Initialisation avec une première ligne vide
    changeDocType();
    addItemRow();
    loadCatalogueFromGitHub();
</script>

</body>
</html>
